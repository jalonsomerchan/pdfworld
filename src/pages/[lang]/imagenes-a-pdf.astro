---
import ImagesToPdfTool from '../../components/ImagesToPdfTool.svelte';
import ToolPageLayout from '../../layouts/ToolPageLayout.astro';
import { getLocalizedPath, isLang, type Lang } from '../../i18n/utils';
import { locales } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

if (!isLang(lang)) {
  return Astro.redirect(getLocalizedPath('es', 'imagenes-a-pdf'));
}

const currentLang = lang as Lang;
const copy = {
  es: {
    title: 'Imágenes a PDF online gratis y privado',
    description: 'Convierte JPG, PNG y WebP a PDF directamente en tu navegador. Ordena imágenes, elige tamaño y orientación, y descarga un PDF sin subir archivos.',
    badge: '100% privado · Sin subidas · En tu navegador',
    h1: 'Imágenes a PDF online',
    lead: 'Crea un PDF a partir de una o varias imágenes JPG, PNG o WebP. Puedes ordenar las miniaturas, elegir tamaño de página y orientación antes de generar el archivo.',
    steps: [
      { text: 'Selecciona o arrastra imágenes JPG, PNG o WebP desde tu dispositivo.' },
      { text: 'Reordena las miniaturas y configura el tamaño de página: A4, carta o ajustar a imagen.' },
      { text: 'Genera el PDF en el navegador, revisa la vista previa y descárgalo.' },
    ],
    infoBlocks: [
      { title: 'Convertir imágenes a PDF sin subir archivos', text: 'La conversión se hace localmente con pdf-lib. Tus imágenes no se envían a servidores y solo existen en tu navegador mientras usas la herramienta.' },
      { title: 'Compatible con formatos comunes', text: 'Puedes mezclar JPG, PNG y WebP, ajustar orientación y mantener el orden que necesites antes de generar el PDF.' },
    ],
    footer: 'Tus archivos se procesan localmente en tu navegador.',
  },
  en: {
    title: 'Images to PDF online for free and privately',
    description: 'Convert JPG, PNG and WebP images to PDF directly in your browser. Reorder images, choose page size and orientation, and download a PDF without uploads.',
    badge: '100% private · No uploads · In your browser',
    h1: 'Images to PDF online',
    lead: 'Create a PDF from one or several JPG, PNG or WebP images. Reorder thumbnails and choose page size and orientation before generating the file.',
    steps: [
      { text: 'Select or drag JPG, PNG or WebP images from your device.' },
      { text: 'Reorder thumbnails and configure the page size: A4, letter or fit to image.' },
      { text: 'Generate the PDF in the browser, review the preview and download it.' },
    ],
    infoBlocks: [
      { title: 'Convert images to PDF without uploads', text: 'The conversion runs locally with pdf-lib. Your images are not sent to servers and only exist in your browser while you use the tool.' },
      { title: 'Compatible with common formats', text: 'You can mix JPG, PNG and WebP, adjust orientation and keep the order you need before generating the PDF.' },
    ],
    footer: 'Your files are processed locally in your browser.',
  },
} as const;

const pageCopy = copy[currentLang];
---

<ToolPageLayout
  lang={currentLang}
  title={pageCopy.title}
  description={pageCopy.description}
  path="imagenes-a-pdf"
  toolId="images-to-pdf"
  badge={pageCopy.badge}
  h1={pageCopy.h1}
  lead={pageCopy.lead}
  steps={pageCopy.steps}
  infoBlocks={pageCopy.infoBlocks}
  footer={pageCopy.footer}
>
  <ImagesToPdfTool client:load lang={currentLang} />
</ToolPageLayout>
