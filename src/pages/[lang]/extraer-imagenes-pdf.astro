---
import ToolPageLayout from '../../layouts/ToolPageLayout.astro';
import ExtractImagesPdfTool from '../../components/ExtractImagesPdfTool.svelte';
import { getLocalizedPath, isLang, type Lang } from '../../i18n/utils';
import { locales } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

if (!isLang(lang)) {
  return Astro.redirect(getLocalizedPath('es', 'extraer-imagenes-pdf'));
}

const copy = {
  es: {
    title: 'Extraer imágenes de PDF online gratis y privado',
    description: 'Convierte páginas de un PDF en imágenes PNG o JPG desde el navegador, sin subir archivos a servidores.',
    badge: '100% privado · Sin subidas · En tu navegador',
    h1: 'Extraer imágenes de PDF',
    lead: 'Carga un PDF, elige páginas, formato PNG o JPG, calidad y resolución, y descarga las páginas renderizadas como imágenes o ZIP.',
    steps: [
      { text: 'Selecciona un archivo PDF desde tu dispositivo.' },
      { text: 'Elige las páginas a exportar, el formato y la resolución.' },
      { text: 'Genera las imágenes y descarga una imagen individual o un ZIP con todas.' },
    ],
    infoBlocks: [
      { title: 'Exportación local y privada', text: 'El PDF se renderiza en el navegador con pdf.js. No se sube a ningún servidor y el archivo original no se modifica.' },
      { title: 'Qué extrae esta herramienta', text: 'La herramienta exporta páginas renderizadas como imágenes. No extrae necesariamente los recursos internos originales incrustados en el PDF.' },
    ],
    footer: 'Tus archivos se procesan localmente en tu navegador.',
  },
  en: {
    title: 'Extract PDF images online for free and privately',
    description: 'Convert PDF pages into PNG or JPG images from the browser, without uploading files to servers.',
    badge: '100% private · No uploads · In your browser',
    h1: 'Extract images from PDF',
    lead: 'Load a PDF, choose pages, PNG or JPG format, quality and resolution, then download rendered pages as images or a ZIP.',
    steps: [
      { text: 'Select a PDF file from your device.' },
      { text: 'Choose the pages to export, the format and the resolution.' },
      { text: 'Generate the images and download a single image or a ZIP with all files.' },
    ],
    infoBlocks: [
      { title: 'Local and private export', text: 'The PDF is rendered in the browser with pdf.js. It is never uploaded to a server and the original file is not changed.' },
      { title: 'What this tool extracts', text: 'The tool exports rendered pages as images. It does not necessarily extract the original internal image resources embedded in the PDF.' },
    ],
    footer: 'Your files are processed locally in your browser.',
  },
} as const;

const pageCopy = copy[lang as Lang];
---

<ToolPageLayout
  lang={lang}
  title={pageCopy.title}
  description={pageCopy.description}
  path="extraer-imagenes-pdf"
  toolId="extract-images-pdf"
  badge={pageCopy.badge}
  h1={pageCopy.h1}
  lead={pageCopy.lead}
  steps={pageCopy.steps}
  infoBlocks={pageCopy.infoBlocks}
  footer={pageCopy.footer}
>
  <ExtractImagesPdfTool client:load lang={lang} />
</ToolPageLayout>
