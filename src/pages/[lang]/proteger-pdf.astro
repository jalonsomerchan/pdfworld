---
import ToolPageLayout from '../../layouts/ToolPageLayout.astro';
import { getLocalizedPath, isLang, type Lang } from '../../i18n/utils';
import { locales } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

if (!isLang(lang)) {
  return Astro.redirect(getLocalizedPath('es', 'proteger-pdf'));
}

const copy = {
  es: {
    title: 'Proteger PDF con contraseña: límites en navegador',
    description: 'Explicación clara sobre por qué FácilPDF no cifra PDFs con contraseña solo en navegador si no puede garantizar seguridad real.',
    badge: 'Seguridad PDF · Sin falsas promesas',
    h1: 'Proteger PDF con contraseña',
    lead: 'FácilPDF prioriza la privacidad local. Por eso esta herramienta no ofrece todavía cifrado de PDF con contraseña si no puede garantizar una protección real y verificable desde el navegador.',
    steps: [
      { text: 'Comprueba si necesitas cifrado real o solo ocultar información de forma visual.' },
      { text: 'Evita confiar en herramientas que solo añaden una contraseña superficial sin cifrar el contenido.' },
      { text: 'Usa una herramienta de escritorio fiable para documentos sensibles hasta que exista una solución frontend validada.' },
    ],
    infoBlocks: [
      { title: 'Estado de la herramienta', text: 'La protección con contraseña está en investigación. Muchas librerías frontend populares permiten editar o generar PDFs, pero no siempre aplican cifrado PDF estándar de forma fiable y compatible con lectores habituales.' },
      { title: 'Por qué no activamos una protección falsa', text: 'Añadir una contraseña visible en una interfaz no significa cifrar el PDF. Una protección incompleta puede dar una falsa sensación de seguridad.' },
      { title: 'Privacidad por defecto', text: 'No enviamos documentos a un servidor externo para cifrarlos, porque rompería la promesa de privacidad local de FácilPDF.' },
    ],
    footer: 'FácilPDF no promete seguridad si técnicamente no puede garantizarla.',
  },
  en: {
    title: 'Protect PDF with password: browser limits',
    description: 'Clear explanation of why FácilPDF does not password-encrypt PDFs in the browser unless real security can be guaranteed.',
    badge: 'PDF security · No false promises',
    h1: 'Protect PDF with password',
    lead: 'FácilPDF prioritizes local privacy. That is why this tool does not yet offer PDF password encryption unless it can guarantee real and verifiable browser-based protection.',
    steps: [
      { text: 'Check whether you need real encryption or only visual hiding.' },
      { text: 'Avoid trusting tools that only add a superficial password without encrypting the content.' },
      { text: 'Use a trusted desktop tool for sensitive documents until a validated frontend solution exists.' },
    ],
    infoBlocks: [
      { title: 'Tool status', text: 'Password protection is under investigation. Many popular frontend libraries can edit or generate PDFs, but they do not always apply standard PDF encryption reliably across common readers.' },
      { title: 'Why we do not enable fake protection', text: 'Adding a password field in an interface does not mean the PDF is encrypted. Incomplete protection can give users a false sense of security.' },
      { title: 'Privacy by default', text: 'We do not send documents to an external server for encryption, because that would break FácilPDF’s local privacy promise.' },
    ],
    footer: 'FácilPDF does not promise security when it cannot technically guarantee it.',
  },
} as const;

const pageCopy = copy[lang as Lang];
---

<ToolPageLayout
  lang={lang}
  title={pageCopy.title}
  description={pageCopy.description}
  path="proteger-pdf"
  toolId="protect-pdf"
  badge={pageCopy.badge}
  h1={pageCopy.h1}
  lead={pageCopy.lead}
  steps={pageCopy.steps}
  infoBlocks={pageCopy.infoBlocks}
  footer={pageCopy.footer}
>
  <section class="tool-notice" role="note">
    <strong>{lang === 'es' ? 'Herramienta informativa' : 'Informational tool'}</strong>
    <p>{lang === 'es' ? 'Esta ruta documenta los límites actuales de cifrar PDFs en el navegador sin subir archivos. No procesa documentos todavía.' : 'This route documents the current limits of encrypting PDFs in the browser without uploads. It does not process documents yet.'}</p>
  </section>
</ToolPageLayout>

<style>
  .tool-notice{padding:clamp(1rem,3vw,1.5rem);border:1px solid #fed7aa;border-radius:1.25rem;background:#fff7ed;color:#9a3412}.tool-notice strong{display:block;margin-bottom:.35rem;color:#7c2d12}.tool-notice p{margin:0}
</style>
