---
import ToolPageLayout from '../../layouts/ToolPageLayout.astro';
import RepairPdfTool from '../../components/RepairPdfTool.svelte';
import { getLocalizedPath, isLang, type Lang } from '../../i18n/utils';
import { locales } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

if (!isLang(lang)) {
  return Astro.redirect(getLocalizedPath('es', 'reparar-pdf'));
}

const copy = {
  es: {
    title: 'Reparar PDF online gratis y privado',
    description: 'Intenta reconstruir un PDF problemático desde el navegador, sin subir archivos a servidores.',
    badge: 'Reparar PDF · Sin subidas · En tu navegador',
    h1: 'Reparar PDF',
    lead: 'Carga un PDF que dé problemas de lectura e intenta generar una copia nueva con la estructura interna reconstruida.',
    steps: [
      { text: 'Selecciona un archivo PDF desde tu dispositivo.' },
      { text: 'La herramienta intenta leer sus páginas y copiarlas a un documento nuevo.' },
      { text: 'Descarga la copia reconstruida y comprueba si abre correctamente.' },
    ],
    infoBlocks: [
      { title: 'Reparación local y privada', text: 'El proceso se realiza en tu navegador con pdf-lib. El PDF no se envía a ningún servidor.' },
      { title: 'Límites de la reparación', text: 'No puede recuperar PDFs gravemente corruptos, incompletos, cifrados sin contraseña o con datos esenciales perdidos. Es una reconstrucción básica para archivos parcialmente legibles.' },
    ],
    footer: 'Tus archivos se procesan localmente en tu navegador.',
  },
  en: {
    title: 'Repair PDF online for free and privately',
    description: 'Try to rebuild a problematic PDF from the browser, without uploading files to servers.',
    badge: 'Repair PDF · No uploads · In your browser',
    h1: 'Repair PDF',
    lead: 'Load a PDF with reading issues and try to generate a new copy with its internal structure rebuilt.',
    steps: [
      { text: 'Select a PDF file from your device.' },
      { text: 'The tool tries to read its pages and copy them into a new document.' },
      { text: 'Download the rebuilt copy and check whether it opens correctly.' },
    ],
    infoBlocks: [
      { title: 'Local and private repair', text: 'The process runs in your browser with pdf-lib. The PDF is not sent to any server.' },
      { title: 'Repair limits', text: 'It cannot recover severely corrupted, incomplete, encrypted-without-password PDFs or files with essential data missing. It is a basic rebuild for partially readable files.' },
    ],
    footer: 'Your files are processed locally in your browser.',
  },
} as const;

const pageCopy = copy[lang as Lang];
---

<ToolPageLayout
  lang={lang}
  title={pageCopy.title}
  description={pageCopy.description}
  path="reparar-pdf"
  toolId="repair-pdf"
  badge={pageCopy.badge}
  h1={pageCopy.h1}
  lead={pageCopy.lead}
  steps={pageCopy.steps}
  infoBlocks={pageCopy.infoBlocks}
  footer={pageCopy.footer}
>
  <RepairPdfTool client:load lang={lang} />
</ToolPageLayout>
