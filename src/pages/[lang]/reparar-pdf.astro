---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RepairPdfTool from '../../components/RepairPdfTool.svelte';
import { getLocalizedPath, isLang, type Lang } from '../../i18n/utils';
import { locales } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

if (!isLang(lang)) {
  return Astro.redirect(getLocalizedPath('es', 'reparar-pdf'));
}

const copy = {
  es: {
    title: 'Reparar PDF online gratis y privado',
    description: 'Intenta reconstruir un PDF problemático desde el navegador, sin subir archivos a servidores.',
    badge: 'Reparar PDF · Sin subidas · En tu navegador',
    h1: 'Reparar PDF',
    lead: 'Carga un PDF que dé problemas de lectura e intenta generar una copia nueva con la estructura interna reconstruida.',
    howTitle: 'Cómo reparar un PDF',
    step1: 'Selecciona un archivo PDF desde tu dispositivo.',
    step2: 'La herramienta intenta leer sus páginas y copiarlas a un documento nuevo.',
    step3: 'Descarga la copia reconstruida y comprueba si abre correctamente.',
    privacyTitle: 'Reparación local y privada',
    privacyText: 'El proceso se realiza en tu navegador con pdf-lib. El PDF no se envía a ningún servidor.',
    limitTitle: 'Límites de la reparación',
    limitText: 'No puede recuperar PDFs gravemente corruptos, incompletos, cifrados sin contraseña o con datos esenciales perdidos. Es una reconstrucción básica para archivos parcialmente legibles.',
    footer: 'Tus archivos se procesan localmente en tu navegador.',
  },
  en: {
    title: 'Repair PDF online for free and privately',
    description: 'Try to rebuild a problematic PDF from the browser, without uploading files to servers.',
    badge: 'Repair PDF · No uploads · In your browser',
    h1: 'Repair PDF',
    lead: 'Load a PDF with reading issues and try to generate a new copy with its internal structure rebuilt.',
    howTitle: 'How to repair a PDF',
    step1: 'Select a PDF file from your device.',
    step2: 'The tool tries to read its pages and copy them into a new document.',
    step3: 'Download the rebuilt copy and check whether it opens correctly.',
    privacyTitle: 'Local and private repair',
    privacyText: 'The process runs in your browser with pdf-lib. The PDF is not sent to any server.',
    limitTitle: 'Repair limits',
    limitText: 'It cannot recover severely corrupted, incomplete, encrypted-without-password PDFs or files with essential data missing. It is a basic rebuild for partially readable files.',
    footer: 'Your files are processed locally in your browser.',
  },
} as const;

const pageCopy = copy[lang as Lang];
---

<BaseLayout lang={lang} title={pageCopy.title} description={pageCopy.description} path="reparar-pdf">
  <section class="hero">
    <span class="badge">{pageCopy.badge}</span>
    <h1>{pageCopy.h1}</h1>
    <p class="lead">{pageCopy.lead}</p>
  </section>

  <RepairPdfTool client:load lang={lang} />

  <section aria-labelledby="how-title">
    <h2 id="how-title">{pageCopy.howTitle}</h2>
    <ol>
      <li>{pageCopy.step1}</li>
      <li>{pageCopy.step2}</li>
      <li>{pageCopy.step3}</li>
    </ol>
  </section>

  <section>
    <h2>{pageCopy.privacyTitle}</h2>
    <p>{pageCopy.privacyText}</p>
  </section>

  <section>
    <h2>{pageCopy.limitTitle}</h2>
    <p>{pageCopy.limitText}</p>
  </section>

  <Fragment slot="footer">{pageCopy.footer}</Fragment>
</BaseLayout>
