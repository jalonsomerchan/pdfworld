---
import DeletePagesPdfTool from '../../components/DeletePagesPdfTool.svelte';
import ToolPageLayout from '../../layouts/ToolPageLayout.astro';
import { getLocalizedPath, isLang, type Lang } from '../../i18n/utils';
import { locales } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

if (!isLang(lang)) {
  return Astro.redirect(getLocalizedPath('es', 'eliminar-paginas-pdf'));
}

const currentLang = lang as Lang;
const copy = {
  es: {
    title: 'Eliminar páginas PDF online gratis y privado',
    description: 'Elimina páginas concretas de un PDF directamente en tu navegador. Gratis, privado y sin subir archivos a ningún servidor.',
    badge: '100% privado · Sin subidas · En tu navegador',
    h1: 'Eliminar páginas de un PDF',
    lead: 'Quita páginas sueltas o rangos completos de un PDF y descarga una copia limpia. El archivo original no se modifica.',
    steps: [
      { text: 'Selecciona un archivo PDF desde tu dispositivo.' },
      { text: 'Introduce las páginas o rangos a eliminar, por ejemplo 2,4-6.' },
      { text: 'Revisa qué páginas se conservarán y descarga una copia nueva.' },
    ],
    infoBlocks: [
      { title: 'Eliminar páginas sin subir archivos', text: 'Todo el proceso ocurre en tu navegador con pdf-lib. FácilPDF no recibe ni almacena tus documentos.' },
      { title: 'Copia segura', text: 'La herramienta genera un nuevo PDF sin tocar el archivo original, para que siempre conserves tu documento de partida.' },
    ],
    footer: 'Tus archivos se procesan localmente en tu navegador.',
  },
  en: {
    title: 'Delete PDF pages online for free and privately',
    description: 'Delete specific pages from a PDF directly in your browser. Free, private and without uploading files to any server.',
    badge: '100% private · No uploads · In your browser',
    h1: 'Delete pages from a PDF',
    lead: 'Remove individual pages or full ranges from a PDF and download a clean copy. The original file is not modified.',
    steps: [
      { text: 'Select a PDF file from your device.' },
      { text: 'Enter the pages or ranges to delete, for example 2,4-6.' },
      { text: 'Review which pages will be kept and download a new copy.' },
    ],
    infoBlocks: [
      { title: 'Delete pages without uploads', text: 'Everything happens in your browser with pdf-lib. FácilPDF does not receive or store your documents.' },
      { title: 'Safe copy', text: 'The tool generates a new PDF without touching the original file, so you always keep your source document.' },
    ],
    footer: 'Your files are processed locally in your browser.',
  },
} as const;

const pageCopy = copy[currentLang];
---

<ToolPageLayout
  lang={currentLang}
  title={pageCopy.title}
  description={pageCopy.description}
  path="eliminar-paginas-pdf"
  toolId="delete-pages-pdf"
  badge={pageCopy.badge}
  h1={pageCopy.h1}
  lead={pageCopy.lead}
  steps={pageCopy.steps}
  infoBlocks={pageCopy.infoBlocks}
  footer={pageCopy.footer}
>
  <DeletePagesPdfTool client:load lang={currentLang} />
</ToolPageLayout>
