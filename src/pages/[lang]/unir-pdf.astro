---
import MergePdfTool from '../../components/MergePdfTool.svelte';
import ToolPageLayout from '../../layouts/ToolPageLayout.astro';
import { isLang, useTranslations, type Lang } from '../../i18n/utils';
import { locales } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

if (!isLang(lang)) {
  return Astro.redirect('/es/unir-pdf');
}

const currentLang = lang as Lang;
const t = useTranslations(currentLang);
const steps = [
  { text: t('tool.merge.step1') },
  { text: t('tool.merge.step2') },
  { text: t('tool.merge.step3') },
];
const infoBlocks = [
  { title: t('tool.merge.privacyTitle'), text: t('tool.merge.privacyText') },
];
---

<ToolPageLayout
  lang={currentLang}
  title={t('tool.merge.seo.title')}
  description={t('tool.merge.seo.description')}
  path="unir-pdf"
  toolId="merge-pdf"
  badge={t('home.privacyBadge')}
  h1={t('tool.merge.h1')}
  lead={t('tool.merge.lead')}
  steps={steps}
  infoBlocks={infoBlocks}
  footer={t('footer.privacy')}
>
  <MergePdfTool client:load lang={currentLang} />
</ToolPageLayout>
