---
import MergePdfTool from '../../components/MergePdfTool.svelte';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { isLang, useTranslations, type Lang } from '../../i18n/utils';
import { locales } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

if (!isLang(lang)) {
  return Astro.redirect('/es/unir-pdf');
}

const t = useTranslations(lang as Lang);
---

<BaseLayout
  lang={lang}
  title={t('tool.merge.seo.title')}
  description={t('tool.merge.seo.description')}
  path="unir-pdf"
>
  <section class="hero">
    <span class="badge">{t('home.privacyBadge')}</span>
    <h1>{t('tool.merge.h1')}</h1>
    <p class="lead">{t('tool.merge.lead')}</p>
  </section>

  <MergePdfTool client:load lang={lang} />

  <section aria-labelledby="how-title">
    <h2 id="how-title">{t('tool.merge.howTitle')}</h2>
    <ol>
      <li>{t('tool.merge.step1')}</li>
      <li>{t('tool.merge.step2')}</li>
      <li>{t('tool.merge.step3')}</li>
    </ol>
  </section>

  <section>
    <h2>{t('tool.merge.privacyTitle')}</h2>
    <p>{t('tool.merge.privacyText')}</p>
  </section>

  <Fragment slot="footer">{t('footer.privacy')}</Fragment>
</BaseLayout>
