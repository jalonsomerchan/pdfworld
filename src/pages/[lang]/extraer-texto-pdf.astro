---
import ExtractTextPdfTool from '../../components/ExtractTextPdfTool.svelte';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { isLang, useTranslations, type Lang } from '../../i18n/utils';
import { locales } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

if (!isLang(lang)) {
  return Astro.redirect('/es/extraer-texto-pdf');
}

const currentLang = lang as Lang;
const t = useTranslations(currentLang);

const copy = currentLang === 'es'
  ? {
      title: 'Extraer texto de PDF online gratis y privado',
      description: 'Extrae el texto seleccionable de un PDF directamente en tu navegador, sin subir archivos y sin backend. Copia el resultado o descárgalo como TXT.',
      h1: 'Extraer texto de PDF online',
      lead: 'Selecciona un PDF con capa de texto y obtén el contenido agrupado por páginas. Todo se procesa localmente en tu navegador.',
      howTitle: 'Cómo extraer texto de un PDF',
      step1: 'Selecciona un archivo PDF desde tu dispositivo.',
      step2: 'La herramienta recorre sus páginas con pdf.js y extrae el texto seleccionable.',
      step3: 'Copia el resultado completo o descárgalo como archivo .txt.',
      privacyTitle: 'Extraer texto PDF sin subir archivos',
      privacyText: 'El PDF se lee en el navegador. No se envía a servidores y no se aplica OCR: si el documento está escaneado o solo contiene imágenes, se mostrará un aviso claro.',
    }
  : {
      title: 'Extract PDF text online for free and privately',
      description: 'Extract selectable text from a PDF directly in your browser, without uploads or backend. Copy the result or download it as TXT.',
      h1: 'Extract PDF text online',
      lead: 'Select a PDF with a text layer and get the content grouped by page. Everything is processed locally in your browser.',
      howTitle: 'How to extract text from a PDF',
      step1: 'Select a PDF file from your device.',
      step2: 'The tool walks through its pages with pdf.js and extracts selectable text.',
      step3: 'Copy the full result or download it as a .txt file.',
      privacyTitle: 'Extract PDF text without uploads',
      privacyText: 'The PDF is read in the browser. It is not sent to servers and OCR is not applied: if the document is scanned or image-only, a clear warning is shown.',
    };
---

<BaseLayout
  lang={currentLang}
  title={copy.title}
  description={copy.description}
  path="extraer-texto-pdf"
>
  <section class="hero">
    <span class="badge">{t('home.privacyBadge')}</span>
    <h1>{copy.h1}</h1>
    <p class="lead">{copy.lead}</p>
  </section>

  <ExtractTextPdfTool client:load lang={currentLang} />

  <section aria-labelledby="how-title">
    <h2 id="how-title">{copy.howTitle}</h2>
    <ol>
      <li>{copy.step1}</li>
      <li>{copy.step2}</li>
      <li>{copy.step3}</li>
    </ol>
  </section>

  <section>
    <h2>{copy.privacyTitle}</h2>
    <p>{copy.privacyText}</p>
  </section>

  <Fragment slot="footer">{t('footer.privacy')}</Fragment>
</BaseLayout>
