---
import ExtractTextPdfTool from '../../components/ExtractTextPdfTool.svelte';
import ToolPageLayout from '../../layouts/ToolPageLayout.astro';
import { isLang, useTranslations, type Lang } from '../../i18n/utils';
import { locales } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

if (!isLang(lang)) {
  return Astro.redirect('/es/extraer-texto-pdf');
}

const currentLang = lang as Lang;
const t = useTranslations(currentLang);

const copy = currentLang === 'es'
  ? {
      title: 'Extraer texto de PDF online gratis y privado',
      description: 'Extrae el texto seleccionable de un PDF directamente en tu navegador, sin subir archivos y sin backend. Copia el resultado o descárgalo como TXT.',
      h1: 'Extraer texto de PDF online',
      lead: 'Selecciona un PDF con capa de texto y obtén el contenido agrupado por páginas. Todo se procesa localmente en tu navegador.',
      steps: [
        { text: 'Selecciona un archivo PDF desde tu dispositivo.' },
        { text: 'La herramienta recorre sus páginas con pdf.js y extrae el texto seleccionable.' },
        { text: 'Copia el resultado completo o descárgalo como archivo .txt.' },
      ],
      infoBlocks: [
        { title: 'Extraer texto PDF sin subir archivos', text: 'El PDF se lee en el navegador. No se envía a servidores y no se aplica OCR.' },
        { title: 'Sin OCR', text: 'Si el documento está escaneado o solo contiene imágenes, la herramienta mostrará un aviso claro en lugar de inventar texto.' },
      ],
    }
  : {
      title: 'Extract PDF text online for free and privately',
      description: 'Extract selectable text from a PDF directly in your browser, without uploads or backend. Copy the result or download it as TXT.',
      h1: 'Extract PDF text online',
      lead: 'Select a PDF with a text layer and get the content grouped by page. Everything is processed locally in your browser.',
      steps: [
        { text: 'Select a PDF file from your device.' },
        { text: 'The tool walks through its pages with pdf.js and extracts selectable text.' },
        { text: 'Copy the full result or download it as a .txt file.' },
      ],
      infoBlocks: [
        { title: 'Extract PDF text without uploads', text: 'The PDF is read in the browser. It is not sent to servers and OCR is not applied.' },
        { title: 'No OCR', text: 'If the document is scanned or image-only, the tool will show a clear warning instead of inventing text.' },
      ],
    };
---

<ToolPageLayout
  lang={currentLang}
  title={copy.title}
  description={copy.description}
  path="extraer-texto-pdf"
  toolId="extract-text-pdf"
  badge={t('home.privacyBadge')}
  h1={copy.h1}
  lead={copy.lead}
  steps={copy.steps}
  infoBlocks={copy.infoBlocks}
  footer={t('footer.privacy')}
>
  <ExtractTextPdfTool client:load lang={currentLang} />
</ToolPageLayout>
