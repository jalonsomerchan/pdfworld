---
import ToolPageLayout from '../../layouts/ToolPageLayout.astro';
import { getLocalizedPath, isLang, type Lang } from '../../i18n/utils';
import { locales } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

if (!isLang(lang)) {
  return Astro.redirect(getLocalizedPath('es', 'desbloquear-pdf'));
}

const copy = {
  es: {
    title: 'Desbloquear PDF con contraseña conocida: límites en navegador',
    description: 'Información clara sobre desbloquear PDFs solo cuando conoces la contraseña y las limitaciones técnicas de hacerlo en navegador sin backend.',
    badge: 'Seguridad PDF · Solo con permiso',
    h1: 'Desbloquear PDF con contraseña conocida',
    lead: 'Esta página explica el enfoque seguro de FácilPDF: solo se contempla abrir PDFs cuando el usuario conoce la contraseña. No se implementa fuerza bruta, cracking ni bypass de protecciones.',
    steps: [
      { text: 'Verifica que conoces la contraseña y tienes permiso para modificar el documento.' },
      { text: 'No uses herramientas que prometan romper contraseñas o saltar protecciones.' },
      { text: 'Usa una solución de escritorio fiable si necesitas exportar una copia sin bloqueo.' },
    ],
    infoBlocks: [
      { title: 'Estado de la herramienta', text: 'La lectura de PDFs protegidos con contraseña puede funcionar en algunos visores basados en pdf.js, pero generar una copia realmente desbloqueada y compatible desde el navegador no es fiable con las librerías actuales del proyecto.' },
      { title: 'Qué no hará FácilPDF', text: 'No probará contraseñas automáticamente, no hará fuerza bruta ni diccionarios, no saltará restricciones de documentos sin permiso y no enviará PDFs a servidores externos.' },
      { title: 'Implementación futura', text: 'La ruta queda preparada para integrar una solución local si se valida una librería que pueda abrir con contraseña conocida y exportar una copia compatible sin backend.' },
    ],
    footer: 'FácilPDF no ayuda a romper contraseñas ni a saltar permisos de documentos.',
  },
  en: {
    title: 'Unlock PDF with known password: browser limits',
    description: 'Clear information about unlocking PDFs only when you know the password and the technical limits of doing it in the browser without a backend.',
    badge: 'PDF security · Permission only',
    h1: 'Unlock PDF with a known password',
    lead: 'This page explains FácilPDF’s safe approach: only opening PDFs when the user knows the password is considered. No brute force, cracking or protection bypass is implemented.',
    steps: [
      { text: 'Verify that you know the password and have permission to modify the document.' },
      { text: 'Do not use tools that promise to break passwords or bypass protections.' },
      { text: 'Use a trusted desktop solution if you need to export an unlocked copy.' },
    ],
    infoBlocks: [
      { title: 'Tool status', text: 'Reading password-protected PDFs may work in some pdf.js-based viewers, but generating a truly unlocked and compatible copy from the browser is not reliable with the current project libraries.' },
      { title: 'What FácilPDF will not do', text: 'It will not try passwords automatically, perform brute force or dictionary attacks, bypass restrictions without permission or send PDFs to external servers.' },
      { title: 'Future implementation', text: 'This route is ready for a local solution if a library is validated that can open with a known password and export a compatible copy without backend.' },
    ],
    footer: 'FácilPDF does not help break passwords or bypass document permissions.',
  },
} as const;

const pageCopy = copy[lang as Lang];
---

<ToolPageLayout
  lang={lang}
  title={pageCopy.title}
  description={pageCopy.description}
  path="desbloquear-pdf"
  toolId="unlock-pdf"
  badge={pageCopy.badge}
  h1={pageCopy.h1}
  lead={pageCopy.lead}
  steps={pageCopy.steps}
  infoBlocks={pageCopy.infoBlocks}
  footer={pageCopy.footer}
>
  <section class="tool-notice" role="note">
    <strong>{lang === 'es' ? 'Solo con contraseña conocida' : 'Known password only'}</strong>
    <p>{lang === 'es' ? 'Esta página documenta el enfoque seguro de desbloqueo. No realiza cracking, fuerza bruta ni bypass de restricciones.' : 'This page documents the safe unlock approach. It does not perform cracking, brute force or protection bypass.'}</p>
  </section>
</ToolPageLayout>

<style>
  .tool-notice{padding:clamp(1rem,3vw,1.5rem);border:1px solid #bfdbfe;border-radius:1.25rem;background:#eff6ff;color:#1e40af}.tool-notice strong{display:block;margin-bottom:.35rem;color:#1e3a8a}.tool-notice p{margin:0}
</style>
