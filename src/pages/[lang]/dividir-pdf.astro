---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SplitPdfTool from '../../components/SplitPdfToolWithPreview.svelte';
import { getLocalizedPath, isLang, useTranslations, type Lang } from '../../i18n/utils';
import { locales } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

if (!isLang(lang)) {
  return Astro.redirect(getLocalizedPath('es', 'dividir-pdf'));
}

const t = useTranslations(lang as Lang);
---

<BaseLayout
  lang={lang}
  title={t('tool.split.seo.title')}
  description={t('tool.split.seo.description')}
  path="dividir-pdf"
>
  <section class="hero">
    <span class="badge">{t('home.privacyBadge')}</span>
    <h1>{t('tool.split.h1')}</h1>
    <p class="lead">{t('tool.split.lead')}</p>
  </section>

  <SplitPdfTool client:load lang={lang} />

  <section aria-labelledby="how-title">
    <h2 id="how-title">{t('tool.split.howTitle')}</h2>
    <ol>
      <li>{t('tool.split.step1')}</li>
      <li>{t('tool.split.step2')}</li>
      <li>{t('tool.split.step3')}</li>
    </ol>
  </section>

  <section>
    <h2>{t('tool.split.privacyTitle')}</h2>
    <p>{t('tool.split.privacyText')}</p>
  </section>

  <Fragment slot="footer">{t('footer.privacy')}</Fragment>
</BaseLayout>
