---
import SplitPdfTool from '../../components/SplitPdfToolWithPreviewClient.svelte';
import ToolPageLayout from '../../layouts/ToolPageLayout.astro';
import { getLocalizedPath, isLang, useTranslations, type Lang } from '../../i18n/utils';
import { locales } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

if (!isLang(lang)) {
  return Astro.redirect(getLocalizedPath('es', 'dividir-pdf'));
}

const currentLang = lang as Lang;
const t = useTranslations(currentLang);
const steps = [
  { text: t('tool.split.step1') },
  { text: t('tool.split.step2') },
  { text: t('tool.split.step3') },
];
const infoBlocks = [
  { title: t('tool.split.privacyTitle'), text: t('tool.split.privacyText') },
];
---

<ToolPageLayout
  lang={currentLang}
  title={t('tool.split.seo.title')}
  description={t('tool.split.seo.description')}
  path="dividir-pdf"
  toolId="split-pdf"
  badge={t('home.privacyBadge')}
  h1={t('tool.split.h1')}
  lead={t('tool.split.lead')}
  steps={steps}
  infoBlocks={infoBlocks}
  footer={t('footer.privacy')}
>
  <SplitPdfTool client:load lang={currentLang} />
</ToolPageLayout>
