---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RotatePdfTool from '../../components/RotatePdfToolPro.svelte';
import { getLocalizedPath, isLang, type Lang } from '../../i18n/utils';
import { locales } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

if (!isLang(lang)) {
  return Astro.redirect(getLocalizedPath('es', 'rotar-pdf'));
}

const copy = {
  es: {
    title: 'Rotar PDF online gratis y privado',
    description: 'Rota visualmente páginas individuales de un PDF directamente en tu navegador. Gratis, privado y sin subir archivos a ningún servidor.',
    badge: '100% privado · Sin subidas · En tu navegador',
    h1: 'Rotar PDF online',
    lead: 'Visualiza miniaturas de cada página, gira páginas individuales o todo el documento y descarga una copia nueva del PDF rotado.',
    howTitle: 'Cómo rotar un PDF',
    step1: 'Selecciona un archivo PDF desde tu dispositivo.',
    step2: 'Usa las miniaturas para girar páginas concretas o aplica giros rápidos a todo el documento.',
    step3: 'Revisa el resumen de cambios y descarga una copia nueva del PDF rotado.',
    privacyTitle: 'Rotar PDF sin subir archivos',
    privacyText: 'La previsualización se genera en el navegador con pdf.js y la modificación final se hace con pdf-lib. El archivo original no se modifica ni se envía a ningún servidor.',
    footer: 'Tus archivos se procesan localmente en tu navegador.',
  },
  en: {
    title: 'Rotate PDF online for free and privately',
    description: 'Visually rotate individual PDF pages directly in your browser. Free, private and without uploading files to any server.',
    badge: '100% private · No uploads · In your browser',
    h1: 'Rotate PDF online',
    lead: 'Preview thumbnails for every page, rotate individual pages or the whole document, and download a new rotated PDF copy.',
    howTitle: 'How to rotate a PDF',
    step1: 'Select a PDF file from your device.',
    step2: 'Use thumbnails to rotate specific pages or apply quick rotations to the whole document.',
    step3: 'Review the change summary and download a new rotated PDF copy.',
    privacyTitle: 'Rotate PDF without uploads',
    privacyText: 'The preview is generated in the browser with pdf.js and the final edit is made with pdf-lib. The original file is not changed and is never sent to a server.',
    footer: 'Your files are processed locally in your browser.',
  },
} as const;

const pageCopy = copy[lang as Lang];
---

<BaseLayout
  lang={lang}
  title={pageCopy.title}
  description={pageCopy.description}
  path="rotar-pdf"
>
  <section class="hero">
    <span class="badge">{pageCopy.badge}</span>
    <h1>{pageCopy.h1}</h1>
    <p class="lead">{pageCopy.lead}</p>
  </section>

  <RotatePdfTool client:load lang={lang} />

  <section aria-labelledby="how-title">
    <h2 id="how-title">{pageCopy.howTitle}</h2>
    <ol>
      <li>{pageCopy.step1}</li>
      <li>{pageCopy.step2}</li>
      <li>{pageCopy.step3}</li>
    </ol>
  </section>

  <section>
    <h2>{pageCopy.privacyTitle}</h2>
    <p>{pageCopy.privacyText}</p>
  </section>

  <Fragment slot="footer">{pageCopy.footer}</Fragment>
</BaseLayout>
