---
import MultiPdfToolImproved from '../../components/MultiPdfToolImproved.svelte';
import ToolPageLayout from '../../layouts/ToolPageLayout.astro';
import { getLocalizedPath, isLang, type Lang } from '../../i18n/utils';
import { locales } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

if (!isLang(lang)) {
  return Astro.redirect(getLocalizedPath('es', 'multiherramienta-pdf'));
}

const currentLang = lang as Lang;
const copy = {
  es: {
    title: 'Multiherramienta PDF online gratis y privada',
    description:
      'Edita PDFs desde una sola herramienta: unir, reordenar, rotar, eliminar, dividir por selección y añadir texto visible sin subir archivos.',
    badge: 'La herramienta principal · Todo en uno · 100% navegador',
    h1: 'Multiherramienta PDF',
    lead:
      'Una sola pantalla para las operaciones más importantes: unir varios PDF, mover páginas, eliminar páginas, rotarlas, extraer una selección y añadir texto visual antes de descargar una copia nueva.',
    steps: [
      { text: 'Sube uno o varios PDFs. La herramienta los carga y prepara sus páginas localmente en tu navegador.' },
      { text: 'Arrastra las miniaturas para cambiar el orden, usa los iconos para rotar o eliminar páginas, y deja seleccionadas las que quieras exportar.' },
      { text: 'Elige si descargar todo o solo la selección, añade texto si lo necesitas y genera el nuevo PDF.' },
    ],
    infoBlocks: [
      { title: 'Una herramienta central sin subir tus archivos', text: 'La multiherramienta trabaja con pdf-lib y pdf.js en el navegador. Los documentos no se envían a un servidor y el PDF generado se crea localmente en tu dispositivo.' },
      { title: 'Primera versión funcional y ampliable', text: 'Esta versión cubre unir, reordenar con drag and drop, rotar, eliminar, dividir por selección y añadir texto visible. Funciones más avanzadas se gestionan como módulos específicos cuando son fiables en frontend.' },
    ],
    footer: 'Tus archivos se procesan localmente en tu navegador.',
  },
  en: {
    title: 'Free private online PDF multitool',
    description:
      'Edit PDFs from one tool: merge, reorder, rotate, delete, split by selection and add visible text without uploads.',
    badge: 'Main tool · All in one · 100% browser-based',
    h1: 'PDF multitool',
    lead:
      'One screen for the most important operations: merge PDFs, move pages, delete pages, rotate them, extract a selection and add visible text before downloading a new copy.',
    steps: [
      { text: 'Upload one or more PDFs. The tool loads and prepares their pages locally in your browser.' },
      { text: 'Drag thumbnails to reorder, use icons to rotate or delete pages, and keep selected the pages you want to export.' },
      { text: 'Choose whether to download everything or only the selection, add text if needed and generate the new PDF.' },
    ],
    infoBlocks: [
      { title: 'A central tool without uploading your files', text: 'The multitool works with pdf-lib and pdf.js in the browser. Documents are not sent to a server and the generated PDF is created locally on your device.' },
      { title: 'Functional and extensible first version', text: 'This version covers merge, drag and drop reorder, rotate, delete, split by selection and visible text insertion. More advanced features are handled as specific modules when reliable on the frontend.' },
    ],
    footer: 'Your files are processed locally in your browser.',
  },
} as const;

const pageCopy = copy[currentLang];
---

<ToolPageLayout
  lang={currentLang}
  title={pageCopy.title}
  description={pageCopy.description}
  path="multiherramienta-pdf"
  toolId="pdf-multitool"
  badge={pageCopy.badge}
  h1={pageCopy.h1}
  lead={pageCopy.lead}
  steps={pageCopy.steps}
  infoBlocks={pageCopy.infoBlocks}
  footer={pageCopy.footer}
>
  <MultiPdfToolImproved client:load lang={currentLang} />
</ToolPageLayout>

<script is:inline>
  (() => {
    const labels = document.documentElement.lang === 'en'
      ? {
          generate: '⚡ View and download PDF',
          enlarge: 'Enlarge thumbnail',
          close: 'Close enlarged thumbnail',
          title: 'Enlarged thumbnail',
          empty: 'The thumbnail is not ready yet.',
        }
      : {
          generate: '⚡ Ver y Descargar PDF',
          enlarge: 'Ampliar miniatura',
          close: 'Cerrar miniatura ampliada',
          title: 'Miniatura ampliada',
          empty: 'La miniatura aún no está lista.',
        };

    let modal = null;

    function closeModal() {
      modal?.remove();
      modal = null;
    }

    function openThumbnail(card) {
      const image = card.querySelector('.multi-page__thumb img');
      const name = card.querySelector('.multi-page__meta strong')?.textContent?.trim() || labels.title;
      const file = card.querySelector('small')?.textContent?.trim() || '';

      closeModal();
      modal = document.createElement('div');
      modal.className = 'multi-thumb-modal';
      modal.setAttribute('role', 'dialog');
      modal.setAttribute('aria-modal', 'true');
      modal.setAttribute('aria-labelledby', 'multi-thumb-modal-title');
      modal.innerHTML = `
        <div class="multi-thumb-modal__panel" role="document">
          <header>
            <div>
              <span>${labels.title}</span>
              <h3 id="multi-thumb-modal-title"></h3>
              <p></p>
            </div>
            <button type="button" aria-label="${labels.close}">×</button>
          </header>
          <div class="multi-thumb-modal__body"></div>
        </div>
      `;

      modal.querySelector('h3').textContent = name;
      modal.querySelector('p').textContent = file;
      const body = modal.querySelector('.multi-thumb-modal__body');

      if (image?.src) {
        const clone = document.createElement('img');
        clone.src = image.src;
        clone.alt = image.alt || name;
        body.append(clone);
      } else {
        const message = document.createElement('p');
        message.className = 'multi-thumb-modal__empty';
        message.textContent = labels.empty;
        body.append(message);
      }

      modal.addEventListener('click', (event) => {
        if (event.target === modal) closeModal();
      });
      modal.querySelector('button')?.addEventListener('click', closeModal);
      document.addEventListener('keydown', handleEscape, { once: true });
      document.body.append(modal);
    }

    function handleEscape(event) {
      if (event.key === 'Escape') closeModal();
    }

    function enhanceMultitool() {
      document.querySelectorAll('.side-actions .secondary-action').forEach((button) => button.remove());

      document.querySelectorAll('.side-actions .primary-action').forEach((button) => {
        const text = button.textContent || '';
        if (!/Generando|Generating/.test(text)) {
          button.textContent = labels.generate;
          button.setAttribute('aria-label', labels.generate.replace('⚡ ', ''));
        }
      });

      document.querySelectorAll('.multi-page').forEach((card) => {
        if (card.querySelector('.multi-page__zoom')) return;
        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'multi-page__zoom';
        button.textContent = '⛶';
        button.setAttribute('aria-label', labels.enlarge);
        button.addEventListener('click', (event) => {
          event.stopPropagation();
          openThumbnail(card);
        });
        card.append(button);
      });
    }

    const observer = new MutationObserver(enhanceMultitool);
    observer.observe(document.body, { childList: true, subtree: true });
    enhanceMultitool();
  })();
</script>

<style is:global>
  .multi-page[draggable='true']:active {
    z-index: 20;
    opacity: 0.92;
    transform: rotate(1.5deg) scale(1.035) !important;
    border-color: var(--color-primary, #2563eb) !important;
    box-shadow:
      0 28px 70px rgb(15 23 42 / 0.32),
      0 0 0 6px color-mix(in srgb, var(--color-primary, #2563eb) 18%, transparent) !important;
  }

  .multi-tool__pages:has(.multi-page--over) .multi-page:not(.multi-page--over) {
    opacity: 0.48;
    filter: saturate(0.75);
    transform: scale(0.985);
  }

  .multi-tool__pages:has(.multi-page--over) .multi-page:hover:not(.multi-page--over) {
    transform: scale(0.985);
  }

  .multi-page--over {
    position: relative;
    z-index: 15;
    opacity: 1 !important;
    filter: none !important;
    transform: translateY(-8px) scale(1.045) !important;
    border-color: var(--color-secondary, #7c3aed) !important;
    box-shadow:
      0 34px 90px rgb(124 58 237 / 0.34),
      0 18px 45px rgb(15 23 42 / 0.22),
      0 0 0 8px color-mix(in srgb, var(--color-secondary, #7c3aed) 25%, transparent) !important;
  }

  .multi-page--over::before {
    content: '';
    position: absolute;
    inset: -14px;
    z-index: -1;
    border-radius: 32px;
    background:
      linear-gradient(135deg,
        color-mix(in srgb, var(--color-secondary, #7c3aed) 20%, transparent),
        color-mix(in srgb, var(--color-primary, #2563eb) 12%, transparent)
      );
    box-shadow:
      inset 0 0 0 2px color-mix(in srgb, var(--color-secondary, #7c3aed) 42%, transparent),
      0 0 0 999px rgb(15 23 42 / 0.02);
  }

  .multi-page--over::after {
    content: 'Soltar aquí';
    position: absolute;
    left: 50%;
    bottom: calc(100% + 0.55rem);
    z-index: 5;
    transform: translateX(-50%);
    padding: 0.38rem 0.75rem;
    border-radius: 999px;
    background: var(--color-secondary, #7c3aed);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 950;
    white-space: nowrap;
    box-shadow: 0 14px 34px rgb(15 23 42 / 0.28);
  }

  html[lang='en'] .multi-page--over::after {
    content: 'Drop here';
  }

  .multi-page__zoom {
    position: absolute;
    right: 0.6rem;
    bottom: 5.7rem;
    z-index: 4;
    display: grid;
    place-items: center;
    width: 2.1rem;
    height: 2.1rem;
    border: 1px solid var(--color-border, #e2e8f0);
    border-radius: 999px;
    background: var(--color-surface, #fff);
    color: var(--color-text, #0f172a);
    box-shadow: var(--shadow-sm, 0 4px 12px rgb(15 23 42 / 0.08));
    cursor: pointer;
    font: inherit;
    font-weight: 950;
  }

  .multi-page__zoom:hover,
  .multi-page__zoom:focus-visible {
    border-color: var(--color-primary, #2563eb);
    color: var(--color-primary, #2563eb);
    outline: 3px solid color-mix(in srgb, var(--color-primary, #2563eb) 18%, transparent);
    outline-offset: 2px;
  }

  .multi-thumb-modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: grid;
    place-items: center;
    padding: 1rem;
    background: rgb(15 23 42 / 0.72);
    backdrop-filter: blur(10px);
  }

  .multi-thumb-modal__panel {
    display: grid;
    gap: 1rem;
    width: min(100%, 52rem);
    max-height: 92vh;
    padding: clamp(0.9rem, 2vw, 1.25rem);
    border: 1px solid color-mix(in srgb, var(--color-border, #e2e8f0) 55%, transparent);
    border-radius: var(--radius-2xl, 1.5rem);
    background: var(--color-surface, #fff);
    box-shadow: var(--shadow-lg, 0 24px 60px rgb(15 23 42 / 0.16));
  }

  .multi-thumb-modal__panel header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: flex-start;
  }

  .multi-thumb-modal__panel header span {
    color: var(--color-text-muted, #475569);
    font-size: 0.8rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .multi-thumb-modal__panel h3,
  .multi-thumb-modal__panel p {
    margin: 0;
  }

  .multi-thumb-modal__panel p {
    color: var(--color-text-muted, #475569);
    font-size: 0.9rem;
    font-weight: 750;
  }

  .multi-thumb-modal__panel button {
    display: grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    border: 0;
    border-radius: 999px;
    background: var(--color-surface-soft, #f1f5f9);
    color: var(--color-text, #0f172a);
    cursor: pointer;
    font: inherit;
    font-size: 1.5rem;
    font-weight: 900;
  }

  .multi-thumb-modal__body {
    display: grid;
    place-items: center;
    overflow: auto;
  }

  .multi-thumb-modal__body img {
    display: block;
    width: auto;
    max-width: 100%;
    max-height: 72vh;
    border-radius: var(--radius-lg, 1rem);
    background: #fff;
    image-rendering: auto;
    box-shadow: 0 20px 55px rgb(15 23 42 / 0.26);
  }

  .multi-thumb-modal__empty {
    margin: 0;
    padding: 1rem;
    color: var(--color-text-muted, #475569);
    font-weight: 800;
  }

  @media (max-width: 900px) {
    .multi-page__zoom {
      bottom: 6.1rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .multi-thumb-modal {
      backdrop-filter: none;
    }
  }
</style>
