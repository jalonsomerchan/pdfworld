---
import ScanPdfTool from '../../components/ScanPdfTool.svelte';
import ToolPageLayout from '../../layouts/ToolPageLayout.astro';
import { isLang, useTranslations, type Lang } from '../../i18n/utils';
import { locales } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

if (!isLang(lang)) {
  return Astro.redirect('/es/escanear-pdf');
}

const currentLang = lang as Lang;
const t = useTranslations(currentLang);
const steps = [
  { text: t('tool.scan.step1') },
  { text: t('tool.scan.step2') },
  { text: t('tool.scan.step3') },
];
const infoBlocks = [
  { title: t('tool.scan.privacyTitle'), text: t('tool.scan.privacyText') },
];
---

<ToolPageLayout
  lang={currentLang}
  title={t('tool.scan.seo.title')}
  description={t('tool.scan.seo.description')}
  path="escanear-pdf"
  toolId="scan-pdf"
  badge={t('home.privacyBadge')}
  h1={t('tool.scan.h1')}
  lead={t('tool.scan.lead')}
  steps={steps}
  infoBlocks={infoBlocks}
  footer={t('footer.privacy')}
>
  <ScanPdfTool client:load lang={currentLang} />
</ToolPageLayout>
