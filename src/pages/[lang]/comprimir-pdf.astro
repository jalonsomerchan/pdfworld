---
import CompressPdfTool from '../../components/CompressPdfTool.svelte';
import ToolPageLayout from '../../layouts/ToolPageLayout.astro';
import { getLocalizedPath, isLang, type Lang } from '../../i18n/utils';
import { locales } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

if (!isLang(lang)) {
  return Astro.redirect(getLocalizedPath('es', 'comprimir-pdf'));
}

const currentLang = lang as Lang;
const copy = {
  es: {
    title: 'Comprimir PDF online gratis y privado',
    description: 'Comprime PDF directamente en tu navegador con una estrategia local basada en pdf.js y pdf-lib. Sin subir archivos a ningún servidor.',
    badge: '100% privado · Sin subidas · En tu navegador',
    h1: 'Comprimir PDF online',
    lead: 'Reduce el peso de un PDF desde el navegador. La herramienta rasteriza páginas, aplica compresión configurable y genera un nuevo documento localmente.',
    steps: [
      { text: 'Selecciona un PDF desde tu dispositivo.' },
      { text: 'Elige el nivel de compresión: suave, recomendado o máximo.' },
      { text: 'Genera el PDF comprimido y compara el tamaño antes de descargarlo.' },
    ],
    infoBlocks: [
      { title: 'Comprimir PDF sin subir archivos', text: 'Todo el proceso ocurre en tu navegador: pdf.js renderiza las páginas y pdf-lib crea el nuevo PDF comprimido.' },
      { title: 'Compresión por rasterizado', text: 'La reducción de tamaño se consigue convirtiendo páginas a imágenes comprimidas, por lo que puede cambiar la nitidez o perder texto seleccionable.' },
    ],
    footer: 'Tus archivos se procesan localmente en tu navegador.',
  },
  en: {
    title: 'Compress PDF online for free and privately',
    description: 'Compress PDFs directly in your browser with a local strategy based on pdf.js and pdf-lib. No files are uploaded to any server.',
    badge: '100% private · No uploads · In your browser',
    h1: 'Compress PDF online',
    lead: 'Reduce PDF size from the browser. The tool rasterizes pages, applies configurable compression and generates a new document locally.',
    steps: [
      { text: 'Select a PDF from your device.' },
      { text: 'Choose a compression level: soft, recommended or maximum.' },
      { text: 'Generate the compressed PDF and compare the size before downloading it.' },
    ],
    infoBlocks: [
      { title: 'Compress PDF without uploads', text: 'Everything happens in your browser: pdf.js renders pages and pdf-lib creates the new compressed PDF.' },
      { title: 'Rasterized compression', text: 'Size reduction is achieved by converting pages to compressed images, so sharpness may change or selectable text may be lost.' },
    ],
    footer: 'Your files are processed locally in your browser.',
  },
} as const;

const pageCopy = copy[currentLang];
---

<ToolPageLayout
  lang={currentLang}
  title={pageCopy.title}
  description={pageCopy.description}
  path="comprimir-pdf"
  toolId="compress-pdf"
  badge={pageCopy.badge}
  h1={pageCopy.h1}
  lead={pageCopy.lead}
  steps={pageCopy.steps}
  infoBlocks={pageCopy.infoBlocks}
  footer={pageCopy.footer}
>
  <CompressPdfTool client:load lang={currentLang} />
</ToolPageLayout>
