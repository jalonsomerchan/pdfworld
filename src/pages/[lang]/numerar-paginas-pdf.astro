---
import ToolPageLayout from '../../layouts/ToolPageLayout.astro';
import PageNumbersPdfTool from '../../components/PageNumbersPdfTool.svelte';
import { getLocalizedPath, isLang, type Lang } from '../../i18n/utils';
import { locales } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

if (!isLang(lang)) {
  return Astro.redirect(getLocalizedPath('es', 'numerar-paginas-pdf'));
}

const copy = {
  es: {
    title: 'Numerar páginas PDF online gratis y privado',
    description: 'Añade números de página a un PDF desde el navegador, con formato, posición, tamaño y margen configurables.',
    badge: '100% privado · Sin subidas · En tu navegador',
    h1: 'Numerar páginas PDF',
    lead: 'Carga un PDF, elige el formato de numeración, posición, tamaño, margen y página inicial, y descarga una copia nueva con números visibles.',
    steps: [
      { text: 'Selecciona un archivo PDF desde tu dispositivo.' },
      { text: 'Configura el texto, posición, tamaño, margen y la página donde empieza la numeración.' },
      { text: 'Genera la vista previa y descarga el PDF numerado.' },
    ],
    infoBlocks: [
      { title: 'Numeración local y privada', text: 'La numeración se añade en el navegador con pdf-lib. El documento original no se modifica ni se envía a ningún servidor.' },
      { title: 'Formato flexible', text: 'Puedes usar marcadores como {n} y {total}, elegir posición, margen y tamaño para adaptar la numeración al documento.' },
    ],
    footer: 'Tus archivos se procesan localmente en tu navegador.',
  },
  en: {
    title: 'Add page numbers to PDF online for free and privately',
    description: 'Add page numbers to a PDF from the browser with configurable format, position, size and margin.',
    badge: '100% private · No uploads · In your browser',
    h1: 'Add page numbers to PDF',
    lead: 'Load a PDF, choose the numbering format, position, size, margin and start page, then download a new copy with visible page numbers.',
    steps: [
      { text: 'Select a PDF file from your device.' },
      { text: 'Configure the text, position, size, margin and the page where numbering starts.' },
      { text: 'Generate the preview and download the numbered PDF.' },
    ],
    infoBlocks: [
      { title: 'Local and private numbering', text: 'Page numbers are added in the browser with pdf-lib. The original document is not changed and is never sent to a server.' },
      { title: 'Flexible format', text: 'You can use markers such as {n} and {total}, choose position, margin and size to adapt numbering to the document.' },
    ],
    footer: 'Your files are processed locally in your browser.',
  },
} as const;

const pageCopy = copy[lang as Lang];
---

<ToolPageLayout
  lang={lang}
  title={pageCopy.title}
  description={pageCopy.description}
  path="numerar-paginas-pdf"
  toolId="page-numbers"
  badge={pageCopy.badge}
  h1={pageCopy.h1}
  lead={pageCopy.lead}
  steps={pageCopy.steps}
  infoBlocks={pageCopy.infoBlocks}
  footer={pageCopy.footer}
>
  <PageNumbersPdfTool client:load lang={lang} />
</ToolPageLayout>
