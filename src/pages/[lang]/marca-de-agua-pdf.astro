---
import WatermarkPdfTool from '../../components/WatermarkPdfTool.svelte';
import ToolPageLayout from '../../layouts/ToolPageLayout.astro';
import { getLocalizedPath, isLang, type Lang } from '../../i18n/utils';
import { locales } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

if (!isLang(lang)) {
  return Astro.redirect(getLocalizedPath('es', 'marca-de-agua-pdf'));
}

const currentLang = lang as Lang;
const copy = {
  es: {
    title: 'Añadir marca de agua a PDF online gratis y privado',
    description: 'Añade una marca de agua de texto a todas o algunas páginas de un PDF desde el navegador, sin subir archivos a servidores.',
    badge: '100% privado · Sin subidas · En tu navegador',
    h1: 'Añadir marca de agua a PDF',
    lead: 'Carga un PDF, escribe el texto de la marca de agua, ajusta tamaño, opacidad, rotación, posición y páginas afectadas, y descarga una copia nueva.',
    steps: [
      { text: 'Selecciona un archivo PDF desde tu dispositivo.' },
      { text: 'Configura el texto, tamaño, opacidad, rotación, posición y rango de páginas.' },
      { text: 'Genera la vista previa y descarga el PDF con la marca de agua aplicada.' },
    ],
    infoBlocks: [
      { title: 'Marca de agua PDF sin subir archivos', text: 'La edición se realiza en el navegador con pdf-lib. El documento original no se modifica ni se envía a ningún servidor.' },
      { title: 'Control visual completo', text: 'Puedes ajustar tamaño, opacidad, rotación, posición y páginas afectadas para adaptar la marca de agua al documento.' },
    ],
    footer: 'Tus archivos se procesan localmente en tu navegador.',
  },
  en: {
    title: 'Add watermark to PDF online for free and privately',
    description: 'Add a text watermark to all or selected PDF pages from the browser, without uploading files to servers.',
    badge: '100% private · No uploads · In your browser',
    h1: 'Add watermark to PDF',
    lead: 'Load a PDF, type the watermark text, adjust size, opacity, rotation, position and affected pages, then download a new copy.',
    steps: [
      { text: 'Select a PDF file from your device.' },
      { text: 'Configure text, size, opacity, rotation, position and page range.' },
      { text: 'Generate the preview and download the PDF with the watermark applied.' },
    ],
    infoBlocks: [
      { title: 'Watermark PDF without uploads', text: 'The edit is performed in the browser with pdf-lib. The original document is not changed and is never sent to a server.' },
      { title: 'Full visual control', text: 'You can adjust size, opacity, rotation, position and affected pages to adapt the watermark to the document.' },
    ],
    footer: 'Your files are processed locally in your browser.',
  },
} as const;

const pageCopy = copy[currentLang];
---

<ToolPageLayout
  lang={currentLang}
  title={pageCopy.title}
  description={pageCopy.description}
  path="marca-de-agua-pdf"
  toolId="watermark-pdf"
  badge={pageCopy.badge}
  h1={pageCopy.h1}
  lead={pageCopy.lead}
  steps={pageCopy.steps}
  infoBlocks={pageCopy.infoBlocks}
  footer={pageCopy.footer}
>
  <WatermarkPdfTool client:load lang={currentLang} />
</ToolPageLayout>
