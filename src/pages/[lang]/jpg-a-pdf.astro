---
import ToolPageLayout from '../../layouts/ToolPageLayout.astro';
import ImagesToPdfTool from '../../components/ImagesToPdfTool.svelte';
import { getLocalizedPath, isLang, type Lang } from '../../i18n/utils';
import { locales } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

if (!isLang(lang)) {
  return Astro.redirect(getLocalizedPath('es', 'jpg-a-pdf'));
}

const copy = {
  es: {
    title: 'Convertir JPG a PDF online gratis y privado',
    description: 'Convierte imágenes JPG en un PDF desde el navegador, sin subir archivos a servidores.',
    badge: 'JPG a PDF · Sin subidas · En tu navegador',
    h1: 'Convertir JPG a PDF',
    lead: 'Selecciona una o varias imágenes JPG, ordénalas, elige tamaño y orientación de página, y descarga un PDF listo para compartir.',
    steps: [
      { text: 'Añade una o varias imágenes JPG desde tu dispositivo.' },
      { text: 'Ordena las imágenes y ajusta el tamaño u orientación del PDF.' },
      { text: 'Genera la vista previa y descarga el documento PDF.' },
    ],
    infoBlocks: [
      { title: 'Conversión local y privada', text: 'Las imágenes se convierten en tu navegador con pdf-lib. No se suben a servidores y el archivo original no se modifica.' },
      { title: 'Orden y tamaño configurables', text: 'Puedes reorganizar las imágenes, elegir A4, carta o ajustar a imagen, y decidir la orientación final del documento.' },
    ],
    footer: 'Tus imágenes se procesan localmente en tu navegador.',
  },
  en: {
    title: 'Convert JPG to PDF online for free and privately',
    description: 'Convert JPG images into a PDF from the browser, without uploading files to servers.',
    badge: 'JPG to PDF · No uploads · In your browser',
    h1: 'Convert JPG to PDF',
    lead: 'Select one or more JPG images, reorder them, choose page size and orientation, then download a PDF ready to share.',
    steps: [
      { text: 'Add one or more JPG images from your device.' },
      { text: 'Reorder the images and adjust PDF page size or orientation.' },
      { text: 'Generate the preview and download the PDF document.' },
    ],
    infoBlocks: [
      { title: 'Local and private conversion', text: 'Images are converted in your browser with pdf-lib. They are not uploaded to servers and the original files are not changed.' },
      { title: 'Configurable order and size', text: 'You can reorder images, choose A4, letter or fit-to-image, and decide the final document orientation.' },
    ],
    footer: 'Your images are processed locally in your browser.',
  },
} as const;

const pageCopy = copy[lang as Lang];
---

<ToolPageLayout
  lang={lang}
  title={pageCopy.title}
  description={pageCopy.description}
  path="jpg-a-pdf"
  toolId="jpg-to-pdf"
  badge={pageCopy.badge}
  h1={pageCopy.h1}
  lead={pageCopy.lead}
  steps={pageCopy.steps}
  infoBlocks={pageCopy.infoBlocks}
  footer={pageCopy.footer}
>
  <ImagesToPdfTool client:load lang={lang} />
</ToolPageLayout>
