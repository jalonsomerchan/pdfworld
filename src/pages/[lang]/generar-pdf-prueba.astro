---
import TestPdfGeneratorTool from '../../components/TestPdfGeneratorTool.svelte';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLocalizedPath, isLang, useTranslations, type Lang } from '../../i18n/utils';
import { locales } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

if (!isLang(lang)) {
  return Astro.redirect(getLocalizedPath('es', 'generar-pdf-prueba'));
}

const t = useTranslations(lang as Lang);
---

<BaseLayout
  lang={lang}
  title={t('tool.testPdf.seo.title')}
  description={t('tool.testPdf.seo.description')}
  path="generar-pdf-prueba"
>
  <section class="hero">
    <span class="badge">{t('home.privacyBadge')}</span>
    <h1>{t('tool.testPdf.h1')}</h1>
    <p class="lead">{t('tool.testPdf.lead')}</p>
  </section>

  <TestPdfGeneratorTool client:load lang={lang} />

  <section aria-labelledby="how-title">
    <h2 id="how-title">{t('tool.testPdf.howTitle')}</h2>
    <ol>
      <li>{t('tool.testPdf.step1')}</li>
      <li>{t('tool.testPdf.step2')}</li>
      <li>{t('tool.testPdf.step3')}</li>
    </ol>
  </section>

  <section>
    <h2>{t('tool.testPdf.privacyTitle')}</h2>
    <p>{t('tool.testPdf.privacyText')}</p>
  </section>

  <Fragment slot="footer">{t('footer.privacy')}</Fragment>
</BaseLayout>
