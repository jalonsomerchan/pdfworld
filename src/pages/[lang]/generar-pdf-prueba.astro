---
import TestPdfGeneratorTool from '../../components/TestPdfGeneratorToolWithPreview.svelte';
import ToolPageLayout from '../../layouts/ToolPageLayout.astro';
import { getLocalizedPath, isLang, useTranslations, type Lang } from '../../i18n/utils';
import { locales } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

if (!isLang(lang)) {
  return Astro.redirect(getLocalizedPath('es', 'generar-pdf-prueba'));
}

const currentLang = lang as Lang;
const t = useTranslations(currentLang);
const steps = [
  { text: t('tool.testPdf.step1') },
  { text: t('tool.testPdf.step2') },
  { text: t('tool.testPdf.step3') },
];
const infoBlocks = [
  { title: t('tool.testPdf.privacyTitle'), text: t('tool.testPdf.privacyText') },
];
---

<ToolPageLayout
  lang={currentLang}
  title={t('tool.testPdf.seo.title')}
  description={t('tool.testPdf.seo.description')}
  path="generar-pdf-prueba"
  toolId="test-pdf-generator"
  badge={t('home.privacyBadge')}
  h1={t('tool.testPdf.h1')}
  lead={t('tool.testPdf.lead')}
  steps={steps}
  infoBlocks={infoBlocks}
  footer={t('footer.privacy')}
>
  <TestPdfGeneratorTool client:load lang={currentLang} />
</ToolPageLayout>
