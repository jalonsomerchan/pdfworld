---
import ReorderPdfTool from '../../components/ReorderPdfToolShared.svelte';
import ToolPageLayout from '../../layouts/ToolPageLayout.astro';
import { getLocalizedPath, isLang, useTranslations, type Lang } from '../../i18n/utils';
import { locales } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

if (!isLang(lang)) {
  return Astro.redirect(getLocalizedPath('es', 'ordenar-pdf'));
}

const currentLang = lang as Lang;
const t = useTranslations(currentLang);
const steps = [
  { text: t('tool.reorder.step1') },
  { text: t('tool.reorder.step2') },
  { text: t('tool.reorder.step3') },
];
const infoBlocks = [
  { title: t('tool.reorder.privacyTitle'), text: t('tool.reorder.privacyText') },
];
---

<ToolPageLayout
  lang={currentLang}
  title={t('tool.reorder.seo.title')}
  description={t('tool.reorder.seo.description')}
  path="ordenar-pdf"
  toolId="reorder-pdf"
  badge={t('home.privacyBadge')}
  h1={t('tool.reorder.h1')}
  lead={t('tool.reorder.lead')}
  steps={steps}
  infoBlocks={infoBlocks}
  footer={t('footer.privacy')}
>
  <ReorderPdfTool client:only="svelte" />
</ToolPageLayout>
