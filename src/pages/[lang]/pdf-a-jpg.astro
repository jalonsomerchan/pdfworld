---
import ToolPageLayout from '../../layouts/ToolPageLayout.astro';
import ExtractImagesPdfTool from '../../components/ExtractImagesPdfTool.svelte';
import { getLocalizedPath, isLang, type Lang } from '../../i18n/utils';
import { locales } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

if (!isLang(lang)) {
  return Astro.redirect(getLocalizedPath('es', 'pdf-a-jpg'));
}

const copy = {
  es: {
    title: 'Convertir PDF a JPG online gratis y privado',
    description: 'Convierte páginas de un PDF en imágenes JPG desde el navegador, sin subir archivos a servidores.',
    badge: 'PDF a JPG · Sin subidas · En tu navegador',
    h1: 'Convertir PDF a JPG',
    lead: 'Carga un PDF, elige páginas o rangos, selecciona JPG, ajusta calidad y resolución, y descarga las páginas como imágenes o ZIP.',
    steps: [
      { text: 'Selecciona un archivo PDF desde tu dispositivo.' },
      { text: 'Elige las páginas que quieres convertir y selecciona formato JPG.' },
      { text: 'Genera las imágenes y descarga una imagen individual o un ZIP.' },
    ],
    infoBlocks: [
      { title: 'Conversión local y privada', text: 'El PDF se renderiza con pdf.js en tu navegador. No se sube a servidores y el archivo original no se modifica.' },
      { title: 'Conversión por renderizado', text: 'La herramienta exporta cada página como imagen JPG renderizada. No extrae recursos internos originales del PDF.' },
    ],
    footer: 'Tus archivos se procesan localmente en tu navegador.',
  },
  en: {
    title: 'Convert PDF to JPG online for free and privately',
    description: 'Convert PDF pages into JPG images from the browser, without uploading files to servers.',
    badge: 'PDF to JPG · No uploads · In your browser',
    h1: 'Convert PDF to JPG',
    lead: 'Load a PDF, choose pages or ranges, select JPG, adjust quality and resolution, then download pages as images or a ZIP.',
    steps: [
      { text: 'Select a PDF file from your device.' },
      { text: 'Choose the pages you want to convert and select JPG format.' },
      { text: 'Generate the images and download a single image or a ZIP.' },
    ],
    infoBlocks: [
      { title: 'Local and private conversion', text: 'The PDF is rendered with pdf.js in your browser. It is not uploaded to servers and the original file is not changed.' },
      { title: 'Rendered page conversion', text: 'The tool exports each page as a rendered JPG image. It does not extract original internal PDF resources.' },
    ],
    footer: 'Your files are processed locally in your browser.',
  },
} as const;

const pageCopy = copy[lang as Lang];
---

<ToolPageLayout
  lang={lang}
  title={pageCopy.title}
  description={pageCopy.description}
  path="pdf-a-jpg"
  toolId="pdf-to-jpg"
  badge={pageCopy.badge}
  h1={pageCopy.h1}
  lead={pageCopy.lead}
  steps={pageCopy.steps}
  infoBlocks={pageCopy.infoBlocks}
  footer={pageCopy.footer}
>
  <ExtractImagesPdfTool client:load lang={lang} />
</ToolPageLayout>
