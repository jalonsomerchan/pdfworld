---
import '../styles/design-system.css';
import { getAlternateLinks, getLocalizedPath, type Lang } from '../i18n/utils';
import { languages } from '../i18n/ui';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  path?: string;
}

const { lang, title, description, path = '' } = Astro.props;
const canonicalUrl = new URL(getLocalizedPath(lang, path), Astro.site);
const alternateLinks = getAlternateLinks(path);
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'PDFWorld',
  url: new URL(getLocalizedPath(lang), Astro.site).toString(),
  inLanguage: lang,
  description,
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {alternateLinks.map((alternate) => (
      <link
        rel="alternate"
        hreflang={alternate.lang}
        href={new URL(alternate.path, Astro.site)}
      />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(getLocalizedPath('es', path), Astro.site)} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="PDFWorld" />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={getLocalizedPath(lang)} aria-label="PDFWorld home">
        <strong>PDFWorld</strong>
      </a>
      <nav class="site-nav" aria-label="Language selector">
        {alternateLinks.map((alternate) => (
          <a
            href={alternate.path}
            class:list={[{ active: alternate.lang === lang }]}
            lang={alternate.lang}
            aria-current={alternate.lang === lang ? 'page' : undefined}
          >
            {languages[alternate.lang]}
          </a>
        ))}
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p><slot name="footer" /></p>
    </footer>
  </body>
</html>
