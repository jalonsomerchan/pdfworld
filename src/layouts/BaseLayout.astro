---
import { getAlternateLinks, getLocalizedPath, type Lang } from '../i18n/utils';
import { languages } from '../i18n/ui';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  path?: string;
}

const { lang, title, description, path = '' } = Astro.props;
const canonicalUrl = new URL(getLocalizedPath(lang, path), Astro.site);
const alternateLinks = getAlternateLinks(path);
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'PDFWorld',
  url: new URL(getLocalizedPath(lang), Astro.site).toString(),
  inLanguage: lang,
  description,
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {alternateLinks.map((alternate) => (
      <link
        rel="alternate"
        hreflang={alternate.lang}
        href={new URL(alternate.path, Astro.site)}
      />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(getLocalizedPath('es', path), Astro.site)} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="PDFWorld" />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={getLocalizedPath(lang)} aria-label="PDFWorld">
        <strong>PDFWorld</strong>
      </a>
      <nav aria-label="Language selector">
        {alternateLinks.map((alternate) => (
          <a
            href={alternate.path}
            class:list={[{ active: alternate.lang === lang }]}
            lang={alternate.lang}
            aria-current={alternate.lang === lang ? 'page' : undefined}
          >
            {languages[alternate.lang]}
          </a>
        ))}
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p><slot name="footer" /></p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: #f8fafc;
    color: #0f172a;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background:
      radial-gradient(circle at top left, rgba(239, 68, 68, 0.12), transparent 32rem),
      #f8fafc;
  }

  a {
    color: inherit;
  }

  .site-header,
  .site-footer,
  main {
    width: min(1120px, calc(100% - 32px));
    margin-inline: auto;
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 24px 0;
  }

  .brand {
    text-decoration: none;
    font-size: 1.25rem;
  }

  nav {
    display: flex;
    gap: 8px;
  }

  nav a {
    padding: 8px 12px;
    border-radius: 999px;
    text-decoration: none;
    color: #475569;
    font-weight: 700;
  }

  nav a.active {
    background: #0f172a;
    color: #fff;
  }

  .site-footer {
    padding: 48px 0;
    color: #64748b;
  }

  .hero {
    padding: 64px 0 40px;
  }

  .badge {
    display: inline-flex;
    margin-bottom: 18px;
    padding: 8px 12px;
    border-radius: 999px;
    background: #dcfce7;
    color: #166534;
    font-weight: 800;
    font-size: 0.9rem;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    font-size: clamp(2.4rem, 7vw, 5.4rem);
    line-height: 0.95;
    letter-spacing: -0.07em;
  }

  h2 {
    margin-top: 48px;
    font-size: clamp(1.7rem, 3vw, 2.6rem);
    letter-spacing: -0.04em;
  }

  p {
    line-height: 1.7;
  }

  .lead {
    max-width: 720px;
    font-size: 1.25rem;
    color: #475569;
  }

  .grid,
  .category-grid,
  .tool-list {
    display: grid;
    gap: 18px;
  }

  .grid,
  .category-grid {
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    margin-top: 24px;
  }

  .tool-list {
    grid-template-columns: 1fr;
    margin-top: 18px;
  }

  .card,
  .category-card,
  .tool-card {
    display: block;
    border: 1px solid #e2e8f0;
    background: rgba(255, 255, 255, 0.82);
    box-shadow: 0 24px 70px rgba(15, 23, 42, 0.08);
    text-decoration: none;
  }

  .card,
  .category-card {
    padding: 24px;
    border-radius: 24px;
  }

  .card h3 {
    margin: 0 0 8px;
    font-size: 1.3rem;
  }

  .card p,
  .category-card p,
  .tool-card p {
    margin: 0;
    color: #64748b;
  }

  .category-card__header {
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }

  .category-card__icon {
    display: inline-grid;
    width: 42px;
    height: 42px;
    flex: 0 0 42px;
    place-items: center;
    border-radius: 14px;
    background: #fee2e2;
    font-size: 1.35rem;
  }

  .category-card h3 {
    margin: 0 0 6px;
    font-size: 1.35rem;
  }

  .category-link {
    display: inline-flex;
    margin-top: 16px;
    color: #b91c1c;
    font-weight: 800;
    text-decoration: none;
  }

  .tool-card {
    padding: 16px;
    border-radius: 18px;
  }

  .tool-card:not(.tool-card--disabled):hover {
    border-color: #f87171;
    transform: translateY(-1px);
  }

  .tool-card--disabled {
    opacity: 0.72;
  }

  .tool-card__title {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-bottom: 8px;
  }

  .status-pill {
    display: inline-flex;
    width: fit-content;
    margin-top: 12px;
    padding: 5px 9px;
    border-radius: 999px;
    background: #e2e8f0;
    color: #475569;
    font-size: 0.78rem;
    font-weight: 800;
  }

  .status-pill--available {
    background: #dcfce7;
    color: #166534;
  }

  .status-pill--beta {
    background: #fef3c7;
    color: #92400e;
  }

  .status-pill--soon {
    background: #e2e8f0;
    color: #475569;
  }
</style>
