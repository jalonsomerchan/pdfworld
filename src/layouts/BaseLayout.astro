---
import { getAlternateLinks, getLocalizedPath, type Lang } from '../i18n/utils';
import { languages } from '../i18n/ui';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  path?: string;
}

const { lang, title, description, path = '' } = Astro.props;
const canonicalUrl = new URL(getLocalizedPath(lang, path), Astro.site);
const alternateLinks = getAlternateLinks(path);
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'PDFWorld',
  url: new URL(getLocalizedPath(lang), Astro.site).toString(),
  inLanguage: lang,
  description,
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {alternateLinks.map((alternate) => (
      <link
        rel="alternate"
        hreflang={alternate.lang}
        href={new URL(alternate.path, Astro.site)}
      />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(getLocalizedPath('es', path), Astro.site)} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="PDFWorld" />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={getLocalizedPath(lang)} aria-label="PDFWorld">
        <strong>PDFWorld</strong>
      </a>
      <nav aria-label="Language selector">
        {alternateLinks.map((alternate) => (
          <a
            href={alternate.path}
            class:list={[{ active: alternate.lang === lang }]}
            lang={alternate.lang}
            aria-current={alternate.lang === lang ? 'page' : undefined}
          >
            {languages[alternate.lang]}
          </a>
        ))}
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p><slot name="footer" /></p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: #f8fafc;
    color: #0f172a;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background:
      radial-gradient(circle at top left, rgba(239, 68, 68, 0.12), transparent 32rem),
      #f8fafc;
  }

  a {
    color: inherit;
  }

  .site-header,
  .site-footer,
  main {
    width: min(1120px, calc(100% - 32px));
    margin-inline: auto;
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 24px 0;
  }

  .brand {
    text-decoration: none;
    font-size: 1.25rem;
  }

  nav {
    display: flex;
    gap: 8px;
  }

  nav a {
    padding: 8px 12px;
    border-radius: 999px;
    text-decoration: none;
    color: #475569;
    font-weight: 700;
  }

  nav a.active {
    background: #0f172a;
    color: #fff;
  }

  .site-footer {
    padding: 48px 0;
    color: #64748b;
  }

  .hero {
    padding: 64px 0 40px;
  }

  .badge {
    display: inline-flex;
    margin-bottom: 18px;
    padding: 8px 12px;
    border-radius: 999px;
    background: #dcfce7;
    color: #166534;
    font-weight: 800;
    font-size: 0.9rem;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    font-size: clamp(2.4rem, 7vw, 5.4rem);
    line-height: 0.95;
    letter-spacing: -0.07em;
  }

  h2 {
    margin-top: 48px;
    font-size: clamp(1.7rem, 3vw, 2.6rem);
    letter-spacing: -0.04em;
  }

  p {
    line-height: 1.7;
  }

  .lead {
    max-width: 720px;
    font-size: 1.25rem;
    color: #475569;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 18px;
    margin-top: 24px;
  }

  .card {
    display: block;
    padding: 24px;
    border: 1px solid #e2e8f0;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.82);
    box-shadow: 0 24px 70px rgba(15, 23, 42, 0.08);
    text-decoration: none;
  }

  .card h3 {
    margin: 0 0 8px;
    font-size: 1.3rem;
  }

  .card p {
    margin: 0;
    color: #64748b;
  }
</style>
