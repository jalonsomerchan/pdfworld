---
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
  ariaLabel?: string;
  compact?: boolean;
}

const { lang, ariaLabel, compact = false } = Astro.props;

const labels = {
  es: {
    aria: 'Ventajas de privacidad y uso de FácilPDF',
    local: 'Procesamiento local',
    free: 'Gratis',
    browser: 'En el navegador',
    noInstall: 'Sin instalación',
  },
  en: {
    aria: 'FácilPDF privacy and usability benefits',
    local: 'Local processing',
    free: 'Free',
    browser: 'In the browser',
    noInstall: 'No installation',
  },
};

const badges = [
  { icon: '🔒', label: labels[lang].local },
  { icon: '⚡', label: labels[lang].free },
  { icon: '🌐', label: labels[lang].browser },
  { icon: '✨', label: labels[lang].noInstall },
];
---

<ul class:list={['trust-badges', { 'trust-badges--compact': compact }]} aria-label={ariaLabel ?? labels[lang].aria}>
  {badges.map((badge) => (
    <li>
      <span aria-hidden="true">{badge.icon}</span>
      {badge.label}
    </li>
  ))}
</ul>
